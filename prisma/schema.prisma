// AlmiGoethe data model. The shared engine foundation (auth, billing, AI cost
// ledger) is forked from AlmiCELPIP. The practice layer is an ITEM-BANK: a single
// GoetheItem ↔ GoetheAttempt pair carries every task type via a typed `payload`
// Json, instead of one model per skill. Scoring is hybrid — deterministic for
// objective modules (Lesen + Hören), AI trait-feedback for productive modules
// (Schreiben + Sprechen) — and is reported as an honest practice POINTS estimate
// per module (max points + 60% pass threshold), never a fabricated total.
//
// The big structural fact vs CELPIP: CELPIP's GENERAL/LS version axis is replaced
// by SIX CEFR LEVELS (A1–C2), and — unlike CELPIP where the version lived only on
// the session — a Goethe item belongs to exactly ONE level (A1 Lesen content is
// not B2 Lesen content), so `level` lives ON THE ITEM and is the primary filter.
// All content is original German, never copied from the Goethe-Institut; results
// are practice estimates — candidates confirm the real requirement with the
// Goethe-Institut / their university / the relevant German authority.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Locale {
  EN
  UR
  AR
  HI
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  passwordHash String
  locale       Locale  @default(EN)
  countryCode  String?
  referralCode String  @unique @default(cuid())

  // Email verification — required before paid feature access.
  emailVerified               DateTime?
  emailVerificationTokenHash  String?   @unique
  emailVerificationExpiresAt  DateTime?
  emailVerificationLastSentAt DateTime?

  // Stripe subscription state — webhook keeps this in lockstep with Stripe.
  stripeCustomerId              String?          @unique
  stripeSubscriptionId          String?          @unique
  subscriptionStatus            String?
  subscriptionPlan              String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean          @default(false)
  trialEndsAt                   DateTime?
  subscriptionTier              SubscriptionTier @default(FREE)

  // Comp Pro access — admin-granted, no Stripe. isProActive()/hasPaidAccess()
  // short-circuit true while compProUntil is in the future, bypassing BOTH the
  // subscription check AND email verification. AlmiGoethe full Pro = AI feedback
  // on Schreiben + Sprechen + the full per-level mock.
  compProUntil  DateTime?
  compGrantedAt DateTime?
  compGrantedBy String?
  compReason    String?

  // Which Dutch exam the user is preparing for (NT2 Programma I/II or Inburgering).
  // Drives the default mock and which practice content is surfaced. Null = not chosen.
  targetExam DutchExam?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  nlAttempts          DutchAttempt[]
  nlSessions          DutchSession[]
  reviews             Review[]

  @@index([email])
  @@index([referralCode])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([compProUntil])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ProcessedWebhook {
  id          String   @id
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model EarlyAccess {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())

  @@index([email])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  text      String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([approved, createdAt])
}

model AICostLedger {
  id               String   @id @default(cuid())
  timestamp        DateTime @default(now())
  userId           String?
  feature          String
  model            String
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costCents        Int
  success          Boolean  @default(true)
  errorMessage     String?

  @@index([timestamp(sort: Desc)])
  @@index([userId, timestamp])
  @@index([feature, timestamp])
}


// ===================== Dutch practice item-bank =====================
// AlmiDutch covers TWO official tracks via ONE item-bank:
//   • NT2 Staatsexamen (CvTE; administered by DUO, delivered by Cito + Bureau
//     ICE) — two programmes: Programma I (B1, work/vocational) and Programma II
//     (B2, higher education/professional). Each tests Reading, Listening,
//     Writing, Speaking; the Diploma NT2 requires passing all four parts.
//     Scored per skill as an honest readiness estimate vs the level's real
//     criteria — never an official CvTE/DUO result.
//   • Inburgering (civic integration, DUO) — four language skills PLUS KNM
//     (Kennis van de Nederlandse Maatschappij) and ONA (Oriëntatie op de
//     Nederlandse Arbeidsmarkt). Level B1 if the integration obligation started
//     on/after 1 Jan 2022 (Wet inburgering 2021), else A2. KNM/ONA are honest
//     practice, clearly labelled "practice, not the official exam result".
// One DutchItem/DutchAttempt pair serves every task type via a typed `payload`
// Json. All content is original; results are practice estimates — confirm the
// real requirement with DUO / IND / the relevant Dutch authority.

enum DutchTrack {
  NT2 // Staatsexamen NT2
  INBURGERING // Civic integration exam
}

// Exam axis. NT2 = two programmes (B1 / B2); Inburgering = A2 or B1 by the date
// the integration obligation started (Wet inburgering 2021).
enum DutchExam {
  PROGRAMMA_I // NT2 — B1 (work / vocational training)
  PROGRAMMA_II // NT2 — B2 (higher education / professional)
  INBURGERING_A2 // Inburgering — A2 (obligation started before 1 Jan 2022)
  INBURGERING_B1 // Inburgering — B1 (obligation on/after 1 Jan 2022)
}

enum DutchSkill {
  READING // Lezen (objective)
  LISTENING // Luisteren (objective)
  WRITING // Schrijven (AI-graded)
  SPEAKING // Spreken (AI-graded)
  KNM // Kennis van de Nederlandse Maatschappij (Inburgering, objective)
  ONA // Oriëntatie op de Nederlandse Arbeidsmarkt (Inburgering, practice)
}

enum DutchTaskType {
  MCQ_SINGLE // objective single-answer multiple choice (Reading/Listening/KNM)
  MATCHING // objective matching
  CLOZE // objective gap-fill (option-per-gap)
  ORDERING // objective sequence
  TRUE_FALSE // objective true/false/not-stated
  WRITING_PROMPT // productive writing (criteria + char band)
  SPEAKING_PROMPT // productive speaking (criteria)
  ONA_TASK // Inburgering labour-market orientation reflection (practice)
}

enum DutchDifficulty {
  FOUNDATION
  CORE
  STRETCH
}

enum DutchAttemptStatus {
  PENDING
  SCORED // objective auto-graded
  EVALUATED // productive AI-graded
  FAILED
}

enum DutchSessionMode {
  PRACTICE
  MOCK
}

enum DutchSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model DutchItem {
  id         String          @id @default(cuid())
  track      DutchTrack
  exam       DutchExam
  skill      DutchSkill
  taskType   DutchTaskType
  difficulty DutchDifficulty @default(CORE)
  title      String
  // Instruction / stem shown to the candidate (NL).
  prompt     String
  // Task-specific structure: objective → { options, passage, transcript, answerKey };
  // productive → { criteria[], charBand, stimulus }. Validated in src/lib/nl/types.
  payload    Json
  // Objective answer key (null for productive/AI tasks).
  answer     Json?
  // Objective max points for this item (0 for productive; readiness is qualitative).
  maxPoints  Int             @default(0)
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  attempts   DutchAttempt[]

  @@index([track, exam, skill, active])
  @@index([exam, skill])
}

model DutchAttempt {
  id        String             @id @default(cuid())
  userId    String
  itemId    String
  sessionId String?
  status    DutchAttemptStatus @default(PENDING)
  // User response: objective → selected answer(s); productive → { text } or { audioKey }.
  response  Json?
  // Objective scoring.
  points    Int?
  maxPoints Int?
  // Productive AI trait feedback: { traits[], summary, estimate }.
  aiFeedback Json?
  // Honest readout: per-skill "CLEAR"|"BORDERLINE"|"BELOW" — never an official result.
  readiness String?
  createdAt   DateTime  @default(now())
  submittedAt DateTime?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item    DutchItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  session DutchSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([itemId])
  @@index([sessionId])
}

model DutchSession {
  id        String             @id @default(cuid())
  userId    String
  track     DutchTrack
  exam      DutchExam
  mode      DutchSessionMode   @default(PRACTICE)
  status    DutchSessionStatus @default(IN_PROGRESS)
  // Aggregate readout: { perSkill: {skill: {points,max,readiness}}, overall }.
  aggregate Json?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts DutchAttempt[]

  @@index([userId, createdAt])
}
